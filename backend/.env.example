PORT=5000
NODE_ENV=development

# Live Server ka port jo browser me dikhe. 5500/5501/5502/5503 sab CORS me allowed hain.
FRONTEND_URL=http://127.0.0.1:5500
CORS_ORIGINS=http://127.0.0.1:5501,http://127.0.0.1:5502,http://127.0.0.1:5503,http://localhost:5500,http://localhost:5501,http://localhost:5502,http://localhost:5503

# MongoDB Atlas URI yahan lagao. Agar blank raha to app crash nahi karega, MOCK MODE me chalega.
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/naxora_institute_os?retryWrites=true&w=majority&appName=Cluster0

JWT_SECRET=replace_this_with_long_secret_key_32_chars_minimum
JWT_EXPIRES_IN=7d

# Razorpay optional. Blank hoga to mock/test mode use hoga.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_COMPANY_NAME=NAXORA Institute OS

# Email optional.
EMAIL_PROVIDER=mock
EMAIL_FROM_NAME=NAXORA Institute OS
EMAIL_FROM_ADDRESS=no-reply@naxora.local
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Part 47 Mongo safety
MONGO_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=15000


# Part 51 secure route cleanup
# In production, keep internal tools disabled so demo/debug/launch pages are not public.
PUBLIC_BASE_URL=http://127.0.0.1:5000
INTERNAL_TOOLS_ENABLED=false
INTERNAL_ADMIN_KEY=change_this_only_for_private_admin_testing
DEMO_MODE_ENABLED=false
